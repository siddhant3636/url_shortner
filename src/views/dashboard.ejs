<%- include("partials/navbar") %>

<h1>Dashboard</h1>

<section>
  <h2>Create Short URL</h2>

  <form id="urlForm">
    <input 
      type="text" 
      id="originalUrl" 
      placeholder="Enter URL"
      required
    />

    <button type="submit">
      Shorten
    </button>
  </form>

  <p id="shortResult"></p>
</section>


<section>

  <h2>Your URLs</h2>

  <table>

    <thead>
      <tr>
        <th>Original URL</th>
        <th>Short URL</th>
        <th>Clicks</th>
        <th>Created</th>
      </tr>
    </thead>

    <tbody id="urlTable">

    </tbody>

  </table>

</section>

<%- include("partials/footer") %>