<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/landing.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <title>Document</title>
</head>
<body class="<%= user ? 'logged-in' : 'logged-out' %>">



<!-- pattern -->
<div class="matrix-container" id="matrixContainer"></div>
  

<!-- Conditional Rendering  -->

<% if (user) { %>
<%- include("partials/navbar") %>

<% } else { %>
 <div class="landing-nav">
    <a href="/api/auth/login"><button class="landing-btn"><span>Login</span></button></a>
    <a href="/api/auth/signup"><button class="landing-btn"><span>Sign Up</span></button></a>
  </div>
<% } %>
  

<!-- Search bar -->
<div class="hero-overlay">
  <h1 class="bangers-regular">Shorten. <span>Analyze.</span> Share.</h1>
<div id="poda">
  <div class="glow"></div>
  <div class="darkBorderBg"></div>
  <div class="darkBorderBg"></div>
  <div class="darkBorderBg"></div>

  <div class="white"></div>

  <div class="border"></div>

  <div id="main">
    <input id="urlInput" placeholder="Enter Your Url Here..." type="text" name="text" class="input" />
    
    <div id="pink-mask"></div>
    <div class="filterBorder"></div>
   <div class="filterBorder"></div>

<button id="filter-icon">
  <svg preserveAspectRatio="none" height="27" width="27" viewBox="0 0 24 24" fill="none">
    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" stroke="#d6d6e6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" stroke="#d6d6e6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
  </svg>
</button>
    <div id="search-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" viewBox="0 0 24 24" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" height="24" fill="none" class="feather feather-search">
        <circle stroke="url(#search)" r="8" cy="11" cx="11"></circle>
        <line stroke="url(#searchl)" y2="16.65" y1="22" x2="16.65" x1="22"></line>
        <defs>
          <linearGradient gradientTransform="rotate(50)" id="search">
            <stop stop-color="#f8e7f8" offset="0%"></stop>
            <stop stop-color="#b6a9b7" offset="50%"></stop>
          </linearGradient>
          <linearGradient id="searchl">
            <stop stop-color="#b6a9b7" offset="0%"></stop>
            <stop stop-color="#837484" offset="50%"></stop>
          </linearGradient>
        </defs>
      </svg>
    </div>
  </div>
</div>




</div> <div class="new-link-wrapper" id="resultWrapper"></div> 




<% if (user) { %>
  <div class="dashboard-content" style="position: relative; z-index: 10; max-width: 1000px; margin: 0 auto; padding: 20px;">
    
    <h2 style="font-family: 'Bangers', system-ui; font-size: 2.5rem; letter-spacing: 2px; text-shadow: 0 0 10px rgba(0,255,65,0.3);">
      Your <span style="color: #00ff41;">Links</span>
    </h2>

    <div style="background: rgba(10,10,10,0.8); border: 1px solid rgba(0, 255, 65, 0.2); border-radius: 12px; padding: 30px; margin-bottom: 100px;">
      
      <% if (urls && urls.length > 0) { %>
        <% urls.forEach(url => { %>
          <div class="url-card" id="card-<%= url._id %>">
    
    <div class="url-info">
        <a href="/api/url/<%= url.shortCode %>" target="_blank" class="short-url dashboard-link-item" data-fullurl="http://<%= currentDomain %>/api/url/<%= url.shortCode %>">
            /<%= url.shortCode %>
        </a>
        <p class="original-url"><%= url.originalUrl %></p>
    </div>
                            
    <div class="url-stats">
        <span class="click-count">
            <span><%= url.clicks %></span> Clicks
        </span>
        
        <button onclick="copyDashboardUrl(this)" class="copy-btn-small">Copy</button>
        <a href="/api/url/<%= url.shortCode %>/analytics" class="analytics-btn">Analytics</a>

        <button onclick="triggerDeleteWarning('<%= url._id %>')" class="delete-link-btn" title="Delete Link">
          <svg viewBox="0 0 448 512" width="14" height="14" fill="#ff003c"><path d="M135.2 17.7L128 32H32C14.3 32 0 46.3 0 64S14.3 96 32 96H416c17.7 0 32-14.3 32-32s-14.3-32-32-32H320l-7.2-14.3C307.4 6.8 296.3 0 284.2 0H163.8c-12.1 0-23.2 6.8-28.6 17.7zM416 128H32L53.2 467c1.6 25.3 22.6 45 47.9 45H346.9c25.3 0 46.3-19.7 47.9-45L416 128z"></path></svg>
        </button>
    </div>
</div>
        <% }) %>
      <% } else { %>
          <div style="text-align: center; padding: 50px 0;">
              <p style="color: #888; font-size: 1.2rem;">You haven't shortened any links yet. Use the bar above!</p>
          </div>
      <% } %>
      
    </div> 

  </div> 

<% } %>

<a href="/admin/login" class="admin-hack-btn" title="System Access">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="hacker-icon" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M2 12h20"></path>
        <path d="M4 12v-2a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v2"></path>
        <circle cx="7" cy="16" r="3"></circle>
        <circle cx="17" cy="16" r="3"></circle>
        <path d="M10 16h4"></path>
    </svg>
</a>

<div id="deleteUrlWarningModal" class="cyber-modal-overlay" style="display: none;">
    <div class="cyber-modal warning-glow" style="text-align: center; max-width: 400px; border-color: #ffeb3b;">
        <div class="modal-icon" style="font-size: 40px; margin-bottom: 15px; animation: pulseWarning 1.5s infinite;">⚠️</div>
        
        <h2 class="bangers-regular" style="color: #ffeb3b; text-shadow: 0 0 10px rgba(255, 235, 59, 0.4);">
            SYSTEM <span style="color: #fff;">WARNING</span>
        </h2>
        
        <p style="color: #ccc; margin-bottom: 25px; font-family: 'Outfit', sans-serif;">
            Are you sure you want to terminate this link? This action is permanent and cannot be undone.
        </p>
        
        <div class="modal-actions" style="display: flex; gap: 15px; justify-content: center;">
            <button class="btn-cancel" onclick="closeModal('deleteUrlWarningModal')">CANCEL</button>
            <button class="btn-confirm-delete" id="confirmUrlDeleteBtn">TERMINATE</button>
        </div>
    </div>
</div>
<script src="/js/landing.js"></script>
<script src="/js/sidebar.js"></script>

</body>
</html>